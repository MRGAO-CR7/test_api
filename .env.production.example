# =============================================================================
# test_api -- production-flavoured .env template
# =============================================================================
#
# This file is the OPPOSITE of .env.example. It carries values intended for
# real deployments (or for the dev environment once the front-end is wired
# correctly), NOT the temporary "let me verify with a Microsoft Graph token"
# values that .env currently uses.
#
# Workflow:
#   - During Phase 4-6 development we kept .env pinned to "Graph token"
#     values so a single-tenant access token from Microsoft Graph would
#     pass auth. That is convenient for local smoke tests but UNSAFE in
#     production: it would let any Graph-targeted token in the tenant
#     authenticate against test_api.
#   - When the SPA / auth_service is fixed to mint a token aimed at THIS
#     API (see "Route A" / "Route B" in README), copy the values from this
#     template into the real .env and redeploy.
#
# Keep this file in source control. Never commit a real .env.
# =============================================================================

APP_NAME=test_api
APP_ENV=production
APP_KEY=                       # php artisan key:generate --show
APP_DEBUG=false                # MUST be false in prod -- turns off stack traces
APP_TIMEZONE=UTC
APP_URL=https://test-api.example.com

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=info                 # info|warning|error in prod, never debug

# -----------------------------------------------------------------------------
# Database (MySQL)
# -----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=                       # "docker-mysql-1" inside compose, or the RDS host
DB_PORT=3306
DB_DATABASE=test
DB_USERNAME=                   # NOT root in prod
DB_PASSWORD=

# -----------------------------------------------------------------------------
# JWT verification -- Route A: scope=openid+profile+email+offline_access
# -----------------------------------------------------------------------------
# These are the values to use when the front-end requests a token without
# Microsoft Graph scopes. The resulting access token has:
#   aud = AZURE_AD_CLIENT_ID  (the GUID of the SPA's app registration)
#   iss = https://<tenant-id>.ciamlogin.com/<tenant-id>/v2.0
#   ver = 2.0
#
# Replace the <PLACEHOLDERS> with values copied from auth_service/.env, then
# verify with:
#   curl ${AZURE_AD_AUTHORITY}/${AZURE_AD_DOMAIN}/v2.0/.well-known/openid-configuration

JWT_JWKS_URI=https://login.microsoftonline.com/<AZURE_AD_TENANT_ID>/discovery/v2.0/keys
JWT_ISSUER=https://<AZURE_AD_TENANT_ID>.ciamlogin.com/<AZURE_AD_TENANT_ID>/v2.0
JWT_AUDIENCE=<AZURE_AD_CLIENT_ID>

# Optional knobs:
JWT_LEEWAY=30
JWT_JWKS_CACHE_TTL=3600
JWT_HTTP_TIMEOUT=5

# Claim name mapping (defaults work for Entra v2.0):
JWT_UUID_CLAIM=sub
JWT_EMAIL_CLAIM=email
JWT_FIRST_NAME_CLAIM=given_name
JWT_LAST_NAME_CLAIM=family_name

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Comma-separated list of origins allowed to call /api/* directly from a
# browser. In normal operation the front-end's BFF talks to test_api
# server-side, so this list can be empty. Populate ONLY for environments
# where a browser (or browser extension) will hit the API directly.
CORS_ALLOWED_ORIGINS=

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------
# Per-user-uuid ceiling for /api/v1/test/me etc. 60/min covers "human user with
# a chatty SPA" comfortably.
RATE_LIMIT_API_USER_PER_MINUTE=60

# Per-IP ceiling for /api/v1/test/health and /api/v1/test/ready. Set high so monitoring
# agents (k8s, datadog) can poll without tripping it.
RATE_LIMIT_PUBLIC_PER_MINUTE=120

# -----------------------------------------------------------------------------
# Misc framework defaults
# -----------------------------------------------------------------------------
BROADCAST_CONNECTION=null
CACHE_STORE=file               # consider redis in prod
QUEUE_CONNECTION=sync          # consider redis/sqs in prod
SESSION_DRIVER=array           # this service is stateless -- no sessions
MAIL_MAILER=log
