{
    "preset": "laravel",
    "rules": {
        "declare_strict_types": true,
        "strict_param": true,
        "ordered_imports": {
            "sort_algorithm": "alpha"
        },
        "global_namespace_import": {
            "import_classes": true,
            "import_constants": true,
            "import_functions": false
        },
        "fully_qualified_strict_types": true,
        "no_superfluous_phpdoc_tags": true
    }
}
