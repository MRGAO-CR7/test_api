## =============================================================================
## test_api — environment template
## =============================================================================

APP_NAME=test_api
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8009

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Host dev: 127.0.0.1. Inside docker: docker-compose overrides DB_HOST to
# `docker-mysql-1` via the `environment:` block.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=test
DB_USERNAME=root
DB_PASSWORD=rootpass

# -----------------------------------------------------------------------------
# Stateless service: cheap drivers, no infra deps.
# -----------------------------------------------------------------------------
SESSION_DRIVER=array
CACHE_STORE=file
QUEUE_CONNECTION=sync
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
MAIL_MAILER=log
BCRYPT_ROUNDS=12

# -----------------------------------------------------------------------------
# JWT verification (Microsoft Entra External ID via auth_service)
# -----------------------------------------------------------------------------
# Required to authenticate any request. If JWT_JWKS_URI is empty, the
# VerifyEntraJwt middleware short-circuits to 503 auth_not_configured.
#
# How to source these values:
#
#   1. Open auth_service/.env and note AZURE_AD_TENANT_ID, AZURE_AD_DOMAIN,
#      AZURE_AD_AUTHORITY, AZURE_AD_CLIENT_ID.
#   2. JWT_JWKS_URI: ALWAYS prefer the tenant-specific v2.0 endpoint:
#        https://login.microsoftonline.com/<AZURE_AD_TENANT_ID>/discovery/v2.0/keys
#      It is a strict superset of `/common/discovery/keys` (covers v1.0 tokens
#      too) AND scoped to your tenant. Do NOT use `/common/discovery/keys`
#      even though Microsoft's v1.0 OIDC discovery doc points at it -- it
#      misses tenant-specific signing keys and is wider in scope than needed.
#   3. JWT_ISSUER: source from the OIDC discovery doc that matches the token
#      version your auth_service mints:
#        - v2.0 tokens (CIAM ciamlogin / login.microsoftonline.com /v2.0/):
#            curl ${AZURE_AD_AUTHORITY}/${AZURE_AD_DOMAIN}/v2.0/.well-known/openid-configuration
#          The `issuer` field uses tenant-GUID-as-subdomain on ciamlogin.
#        - v1.0 tokens (sts.windows.net):
#            curl https://login.microsoftonline.com/<AZURE_AD_TENANT_ID>/.well-known/openid-configuration
#          The `issuer` is `https://sts.windows.net/<tenant_id>/` (trailing /).
#   4. JWT_AUDIENCE is the access-token aud claim. For Entra External ID
#      Native Auth flows with scope=openid profile email offline_access,
#      that is the AZURE_AD_CLIENT_ID GUID. If you change scopes to target
#      Microsoft Graph, set this to 00000003-0000-0000-c000-000000000000.
#
# Example (do NOT commit real values here -- put them in .env only):
#   JWT_JWKS_URI=https://login.microsoftonline.com/<tenant_id>/discovery/v2.0/keys
#   JWT_ISSUER=https://<tenant_id>.ciamlogin.com/<tenant_id>/v2.0   # v2.0 (CIAM)
#   # JWT_ISSUER=https://sts.windows.net/<tenant_id>/                # v1.0 (sts)
#   JWT_AUDIENCE=<azure_ad_client_id_guid>
JWT_JWKS_URI=
JWT_ISSUER=
JWT_AUDIENCE=

# Optional knobs (defaults shown):
JWT_LEEWAY=30
JWT_JWKS_CACHE_TTL=3600
JWT_HTTP_TIMEOUT=5

# Claim name mapping. Override per env if your IdP uses different names.
JWT_UUID_CLAIM=sub
JWT_EMAIL_CLAIM=email
JWT_FIRST_NAME_CLAIM=given_name
JWT_LAST_NAME_CLAIM=family_name
