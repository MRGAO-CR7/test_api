includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: 8
    paths:
        - app
        - routes
        - tests
    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        # Pest closures bind $this to TestCase at runtime; phpstan can't see that.
        - identifier: method.notFound
          path: tests/*
